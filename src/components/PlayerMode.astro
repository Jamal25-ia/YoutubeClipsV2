<div id="playerMode" class="player-mode d-none">
    <!-- Título del clip arriba, centrado y grande -->
    <div class="container mt-4 mb-3">
        <div class="row">
            <div class="col-12 text-center">
                <h1 id="playerTitle" class="clip-title display-5 text-white">Cargando clip...</h1>
                <p class="text-muted mt-2">
                    <span id="timeRange" class="badge bg-secondary"></span>
                </p>
            </div>
        </div>
    </div>

    <!-- Video centrado y grande -->
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10 col-xl-8 position-relative">
                <div class="ratio ratio-16x9 bg-black rounded-3 overflow-hidden shadow-lg">
                    <div id="ytPlayerViewer"></div>
                </div>
            </div>
        </div>
        
        <!-- Controles debajo del video -->
        <div class="row justify-content-center mt-4">
            <div class="col-12 col-lg-10 col-xl-8 text-center">
                <button id="replayBtn" class="btn btn-outline-light btn-lg me-2">
                    <i class="bi bi-arrow-clockwise"></i> Reproducir de nuevo
                </button>
                <button id="goToEditorBtn" class="btn btn-danger btn-lg">
                    <i class="bi bi-pencil-square"></i> Crear mi propio clip
                </button>
            </div>
        </div>
    </div>

    <!-- Botón flotante opcional para ir al editor (móvil) -->
    <button id="editFab" class="btn btn-danger edit-fab player-only">
        <i class="bi bi-pencil"></i> Editar
    </button>

    <!-- ==================== OVERLAY MÓVIL: TOCAR PARA REPRODUCIR ==================== -->
    <div id="mobileStartOverlay" class="d-none">
        <div class="start-overlay-content">
            <h2 id="overlayTitle">Clip de YouTube</h2>
            <p id="overlayTime">0:00 - 0:00</p>
            <button id="overlayPlayBtn" class="btn-play-giant">
                <i class="bi bi-play-fill"></i>
            </button>
            <p class="mt-3 text-muted small">Toca para reproducir con sonido</p>
        </div>
    </div>
</div>