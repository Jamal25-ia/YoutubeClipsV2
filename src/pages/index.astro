---
// Lógica de servidor (Astro) - Por ahora vacía, pero lista para el backend
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>YouTube Clipper - Prototipo</title>
    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">
    <div class="container mt-5">
        <h1 class="mb-4">Video Clipper MVP</h1>

        <!-- Input para pegar la URL del video -->
        <div class="row mb-3">
            <div class="col-8">
                <label class="form-label">Pega la URL del video (MP4 directo para el prototipo)</label>
                <input type="text" id="videoUrl" class="form-control" placeholder="https://ejemplo.com/video.mp4" />
            </div>
            <div class="col-4 d-flex align-items-end">
                <button id="loadVideoBtn" class="btn btn-primary w-100">Cargar Video</button>
            </div>
        </div>

        <div class="row">
            <!-- Columna del Video -->
            <div class="col-md-8">
                <div class="ratio ratio-16x9 bg-secondary">
                    <video id="videoPlayer" controls>
                        <source src="" type="video/mp4" />
                        Tu navegador no soporta el video.
                    </video>
                </div>
            </div>

            <!-- Columna de Controles del Clip -->
            <div class="col-md-4 mt-3 mt-md-0">
                <div class="card bg-secondary text-light">
                    <div class="card-body">
                        <h5 class="card-title">Crear Clip (Max 60s)</h5>
                        
                        <div class="mb-3">
                            <label class="form-label">Inicio (Start)</label>
                            <div class="input-group">
                                <input type="number" id="startTime" class="form-control" step="0.1" value="0" />
                                <button id="setStartBtn" class="btn btn-outline-light">Usar actual</button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Fin (End)</label>
                            <div class="input-group">
                                <input type="number" id="endTime" class="form-control" step="0.1" value="0" />
                                <button id="setEndBtn" class="btn btn-outline-light">Usar actual</button>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button id="previewBtn" class="btn btn-warning">Previsualizar Clip</button>
                            <button id="generateBtn" class="btn btn-success">Generar Clip (Simular)</button>
                        </div>

                        <div id="resultMsg" class="mt-3 text-center fw-bold"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Lógica de cliente -->
    <script>
        // 1. Seleccionar elementos del DOM
        const videoPlayer = document.getElementById('videoPlayer') as HTMLVideoElement;
        const videoUrlInput = document.getElementById('videoUrl') as HTMLInputElement;
        const loadVideoBtn = document.getElementById('loadVideoBtn') as HTMLButtonElement;
        
        const startTimeInput = document.getElementById('startTime') as HTMLInputElement;
        const endTimeInput = document.getElementById('endTime') as HTMLInputElement;
        const setStartBtn = document.getElementById('setStartBtn') as HTMLButtonElement;
        const setEndBtn = document.getElementById('setEndBtn') as HTMLButtonElement;
        
        const previewBtn = document.getElementById('previewBtn') as HTMLButtonElement;
        const generateBtn = document.getElementById('generateBtn') as HTMLButtonElement;
        const resultMsg = document.getElementById('resultMsg') as HTMLDivElement;

        // 2. Cargar Video
        loadVideoBtn.addEventListener('click', () => {
            const url = videoUrlInput.value;
            if (url) {
                videoPlayer.src = url;
                videoPlayer.load();
            }
        });

        // 3. Capturar tiempos actuales del video
        setStartBtn.addEventListener('click', () => {
            startTimeInput.value = videoPlayer.currentTime.toFixed(1);
        });

        setEndBtn.addEventListener('click', () => {
            endTimeInput.value = videoPlayer.currentTime.toFixed(1);
        });

        // 4. Previsualizar el Clip (Reproduce solo en el rango)
        previewBtn.addEventListener('click', () => {
            const start = parseFloat(startTimeInput.value) || 0;
            const end = parseFloat(endTimeInput.value) || 0;

            // Validación de 60 segundos
            if (end - start > 60) {
                resultMsg.innerHTML = '<span class="text-danger">Error: El clip no puede durar más de 60 segundos.</span>';
                return;
            }
            if (end <= start) {
                resultMsg.innerHTML = '<span class="text-danger">Error: El tiempo de fin debe ser mayor al de inicio.</span>';
                return;
            }

            resultMsg.innerHTML = ''; // Limpiar errores
            
            // Mover el video al inicio y reproducir
            videoPlayer.currentTime = start;
            videoPlayer.play();

            // Detener el video cuando llegue al tiempo de fin
            const checkTime = () => {
                if (videoPlayer.currentTime >= end) {
                    videoPlayer.pause();
                    videoPlayer.removeEventListener('timeupdate', checkTime);
                }
            };
            videoPlayer.addEventListener('timeupdate', checkTime);
        });

        // 5. Simular generación del clip (Aquí iría la llamada al backend en el futuro)
        generateBtn.addEventListener('click', () => {
            const start = parseFloat(startTimeInput.value) || 0;
            const end = parseFloat(endTimeInput.value) || 0;

            if (end - start > 60 || end <= start) {
                resultMsg.innerHTML = '<span class="text-danger">Revisa los tiempos. Max 60s.</span>';
                return;
            }

            resultMsg.innerHTML = '<span class="text-success">¡Clip generado! (Simulado)</span>';
            console.log(`Clip generado: Start ${start}s - End ${end}s`);
        });
    </script>
</body>
</html>