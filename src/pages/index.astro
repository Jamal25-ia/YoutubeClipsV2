---
// Lógica de servidor (Astro)
---
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>YouTube Clipper - Prototipo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        #ytPlayer { width: 100%; height: 100%; }
        /* Centrar el reproductor cuando estamos en modo visualizador */
        #viewerUI .ratio { max-width: 900px; margin: 0 auto; }
    </style>
</head>
<body class="bg-dark text-light">

    <!-- ========================================== -->
    <!-- MODO VISUALIZADOR (Se muestra con enlace)  -->
    <!-- ========================================== -->
    <div id="viewerUI" class="container mt-5 d-none">
        <div class="text-center mb-4">
            <h1 id="clipTitle" class="display-5 fw-bold text-info"></h1>
            <p class="text-secondary">Clip compartido de YouTube</p>
        </div>
        <div class="ratio ratio-16x9 bg-black shadow-lg rounded overflow-hidden">
            <div id="ytPlayerViewer"></div>
        </div>
        <div id="viewerMsg" class="text-center mt-3 fw-bold"></div>
    </div>


    <!-- ========================================== -->
    <!-- MODO CREADOR (Interfaz original)           -->
    <!-- ========================================== -->
    <div id="creatorUI" class="container mt-5">
        <h1 class="mb-4">YouTube Clipper MVP</h1>

        <div class="row mb-3">
            <div class="col-8">
                <label class="form-label">Pega la URL del video de YouTube</label>
                <input type="text" id="videoUrl" class="form-control" placeholder="https://youtu.be/LXahKcZU3fo" />
            </div>
            <div class="col-4 d-flex align-items-end">
                <button id="loadVideoBtn" class="btn btn-danger w-100">Cargar Video</button>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="ratio ratio-16x9 bg-secondary">
                    <div id="ytPlayer"></div>
                </div>
            </div>

            <div class="col-md-4 mt-3 mt-md-0">
                <div class="card bg-secondary text-light">
                    <div class="card-body">
                        <h5 class="card-title">Crear Clip (Max 60s)</h5>
                        
                        <!-- NUEVO: Campo para el título -->
                        <div class="mb-3">
                            <label class="form-label">Título del clip</label>
                            <input type="text" id="clipTitleInput" class="form-control" placeholder="Ej: Golazo increíble" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Inicio (Start) - Segundos</label>
                            <div class="input-group">
                                <input type="number" id="startTime" class="form-control" step="1" value="0" />
                                <button id="setStartBtn" class="btn btn-outline-light">Usar actual</button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Fin (End) - Segundos</label>
                            <div class="input-group">
                                <input type="number" id="endTime" class="form-control" step="1" value="0" />
                                <button id="setEndBtn" class="btn btn-outline-light">Usar actual</button>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button id="previewBtn" class="btn btn-warning" disabled>Cargar video primero</button>
                            <button id="generateBtn" class="btn btn-success" disabled>Generar Enlace Compartible</button>
                        </div>

                        <div id="resultMsg" class="mt-3 text-center fw-bold"></div>
                        
                        <div id="shareLinkContainer" class="mt-3 d-none">
                            <label class="form-label fw-bold text-info">Enlace para compartir:</label>
                            <div class="input-group">
                                <input type="text" id="shareLink" class="form-control" readonly />
                                <button id="copyLinkBtn" class="btn btn-outline-info">Copiar</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let creatorPlayer;
        let viewerPlayer;
        let isCreatorPlayerReady = false;
        let previewInterval = null;
        let currentVideoId = null;

        // Elementos del DOM Creador
        const creatorUI = document.getElementById('creatorUI');
        const videoUrlInput = document.getElementById('videoUrl');
        const loadVideoBtn = document.getElementById('loadVideoBtn');
        const clipTitleInput = document.getElementById('clipTitleInput');
        const startTimeInput = document.getElementById('startTime');
        const endTimeInput = document.getElementById('endTime');
        const setStartBtn = document.getElementById('setStartBtn');
        const setEndBtn = document.getElementById('setEndBtn');
        const previewBtn = document.getElementById('previewBtn');
        const generateBtn = document.getElementById('generateBtn');
        const resultMsg = document.getElementById('resultMsg');
        const shareLinkContainer = document.getElementById('shareLinkContainer');
        const shareLinkInput = document.getElementById('shareLink');
        const copyLinkBtn = document.getElementById('copyLinkBtn');

        // Elementos del DOM Visualizador
        const viewerUI = document.getElementById('viewerUI');
        const clipTitle = document.getElementById('clipTitle');
        const viewerMsg = document.getElementById('viewerMsg');

        // Cargar API de YouTube
        const tag = document.createElement('script');
        tag.src = "https://www.youtube.com/iframe_api";
        document.head.appendChild(tag);

        window.onYouTubeIframeAPIReady = () => {
            // Al cargar la página, revisar si es un enlace compartido
            checkUrlForClip();
        };

        function getYoutubeId(url) {
            const regExp = /^.*(youtu\.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
            const match = url.match(regExp);
            return (match && match[2].length === 11) ? match[2] : null;
        }

        // ==========================================
        // LÓGICA MODO CREADOR
        // ==========================================
        function loadVideoById(id) {
            currentVideoId = id;
            shareLinkContainer.classList.add('d-none');

            if (creatorPlayer && isCreatorPlayerReady) {
                creatorPlayer.loadVideoById(id);
            } else {
                creatorPlayer = new YT.Player('ytPlayer', {
                    videoId: id,
                    playerVars: { 'playsinline': 1, 'modestbranding': 1 },
                    events: {
                        'onReady': () => {
                            isCreatorPlayerReady = true;
                            previewBtn.disabled = false;
                            previewBtn.innerText = "Previsualizar Clip";
                            generateBtn.disabled = false;
                        }
                    }
                });
            }
        }

        loadVideoBtn.addEventListener('click', () => {
            const url = videoUrlInput.value;
            const videoId = getYoutubeId(url);
            if (!videoId) {
                resultMsg.innerHTML = '<span class="text-danger">URL no válida.</span>';
                return;
            }
            resultMsg.innerHTML = ''; 
            loadVideoById(videoId);
        });

        setStartBtn.addEventListener('click', () => { if (isCreatorPlayerReady) startTimeInput.value = Math.round(creatorPlayer.getCurrentTime()); });
        setEndBtn.addEventListener('click', () => { if (isCreatorPlayerReady) endTimeInput.value = Math.round(creatorPlayer.getCurrentTime()); });

        previewBtn.addEventListener('click', () => {
            if (!isCreatorPlayerReady) return;
            const start = parseInt(startTimeInput.value) || 0;
            const end = parseInt(endTimeInput.value) || 0;

            if (end - start > 60 || end <= start) {
                resultMsg.innerHTML = '<span class="text-danger">Error: Revisa los tiempos (Max 60s y Fin > Inicio).</span>';
                return;
            }

            resultMsg.innerHTML = '<span class="text-info">Reproduciendo clip...</span>';
            if (previewInterval) clearInterval(previewInterval);

            creatorPlayer.seekTo(start, true);
            creatorPlayer.playVideo();

            previewInterval = setInterval(() => {
                if (creatorPlayer.getCurrentTime() >= end) {
                    creatorPlayer.pauseVideo();
                    clearInterval(previewInterval);
                    previewInterval = null;
                    resultMsg.innerHTML = '<span class="text-light">Clip terminado.</span>';
                }
            }, 100);
        });

        generateBtn.addEventListener('click', () => {
            const start = parseInt(startTimeInput.value) || 0;
            const end = parseInt(endTimeInput.value) || 0;
            const title = clipTitleInput.value.trim() || "Clip de YouTube";

            if (end - start > 60 || end <= start) {
                resultMsg.innerHTML = '<span class="text-danger">Revisa los tiempos. Max 60s.</span>';
                return;
            }

            // Generar URL limpia con el título codificado
            const baseUrl = window.location.origin + window.location.pathname;
            const shareUrl = `${baseUrl}?v=${currentVideoId}&start=${start}&end=${end}&title=${encodeURIComponent(title)}`;

            shareLinkInput.value = shareUrl;
            shareLinkContainer.classList.remove('d-none');
            resultMsg.innerHTML = '<span class="text-success">¡Enlace generado! Compártelo.</span>';
        });

        copyLinkBtn.addEventListener('click', () => {
            navigator.clipboard.writeText(shareLinkInput.value).then(() => {
                resultMsg.innerHTML = '<span class="text-success">¡Copiado al portapapeles!</span>';
            });
        });

        // ==========================================
        // LÓGICA MODO VISUALIZADOR (ENLACE COMPARTIDO)
        // ==========================================
        function checkUrlForClip() {
            const params = new URLSearchParams(window.location.search);
            const videoId = params.get('v');
            const start = parseInt(params.get('start')) || 0;
            const end = parseInt(params.get('end')) || 0;
            const title = params.get('title');

            if (videoId && start !== 0 && end !== 0) {
                // Cambiar de interfaz
                creatorUI.classList.add('d-none');
                viewerUI.classList.remove('d-none');
                
                // Poner el título arriba
                clipTitle.innerText = decodeURIComponent(title || "Clip de YouTube");
                document.title = decodeURIComponent(title || "Clip de YouTube");

                // Iniciar reproductor bloqueado
                viewerPlayer = new YT.Player('ytPlayerViewer', {
                    videoId: videoId,
                    playerVars: { 
                        'playsinline': 1, 
                        'autoplay': 1, 
                        'start': start,
                        'controls': 0,      // Oculta controles de YT
                        'disablekb': 1,     // Desactiva teclado
                        'fs': 0,            // Quita botón de pantalla completa
                        'modestbranding': 1,
                        'rel': 0            // No muestra videos relacionados al final
                    },
                    events: {
                        'onReady': (event) => {
                            enforceViewerClip(start, end);
                        },
                        'onStateChange': (event) => {
                            // Si el usuario intenta adelantar/retroceder de forma fraudulenta, lo regresamos
                            if (event.data === YT.PlayerState.PLAYING) {
                                enforceViewerClip(start, end);
                            }
                        }
                    }
                });
            }
        }

        // Función estricta para que SOLO se reproduzca el fragmento
        function enforceViewerClip(start, end) {
            if (viewerInterval) clearInterval(viewerInterval);
            
            viewerInterval = setInterval(() => {
                const currentTime = viewerPlayer.getCurrentTime();
                if (currentTime < start - 0.5 || currentTime >= end) {
                    viewerPlayer.pauseVideo();
                    viewerPlayer.seekTo(start, true);
                    clearInterval(viewerInterval);
                    viewerMsg.innerHTML = '<span class="text-warning">El clip ha terminado. <a href="#" onclick="location.reload()" class="text-info">Repetir</a></span>';
                }
            }, 50); // Intervalo rápido (50ms) para evitar saltos
        }
    </script>
    <!-- Creado por Jamal25-ia-->
</body>
</html>